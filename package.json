{
  "name": "suliv",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "web": "npm run dev -w @suliv/web",
    "mobile": "npm run start -w @suliv/mobile",
    "mobile:clear": "npm run start:dev:clear -w @suliv/mobile",
    "mobile:ios": "npm run ios -w @suliv/mobile",
    "mobile:android": "npm run android -w @suliv/mobile",
    "db:generate": "npm run db:generate -w @suliv/db",
    "db:migrate": "npm run db:migrate -w @suliv/db",
    "db:studio": "npm run db:studio -w @suliv/db",
    "db:seed": "npm run db:seed -w @suliv/db"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
