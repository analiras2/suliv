{
  "name": "@suliv/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "sh -c 'set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma generate'",
    "db:migrate": "sh -c 'set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate dev'",
    "db:studio": "sh -c 'set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma studio'",
    "db:seed": "sh -c 'set -a; [ -f ../../.env ] && . ../../.env; set +a; ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts'"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "typescript": "*"
  }
}
