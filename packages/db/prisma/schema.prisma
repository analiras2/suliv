// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Provider {
  google
  apple
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailConfirmed Boolean   @default(false)
  passwordHash   String?   // null for social-only users
  avatarUrl      String?
  createdAt      DateTime  @default(now())
  lastActiveAt   DateTime  @default(now()) @updatedAt

  profile       UserProfile?
  accounts      Account[]
  refreshTokens RefreshToken[]
  favorites     UserFavorite[]

  @@map("users")
}

model UserProfile {
  id                  String     @id @default(cuid())
  userId              String     @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietaryRestrictions      String[]
  allergens                String[]
  preferredCuisines        String[]
  skillLevel               SkillLevel?
  cookingFrequencyPerWeek  Int?        // times per week: 1, 3, 5, 7
  avgCookTimeMin           Int?
  householdSize            Int?
  onboardingCompleted      Boolean     @default(false)
  updatedAt           DateTime   @updatedAt

  @@map("user_profiles")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          Provider
  providerAccountId String

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // hash of raw token — never store raw
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime? // null = active

  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Recipe models
// ---------------------------------------------------------------------------

model Recipe {
  id                 String    @id @default(cuid())
  title              String
  slug               String    @unique
  tags               String[]
  prepTimeMin        Int
  cookTimeMin        Int
  difficulty         SkillLevel
  category           String    // 'cafe' | 'almoco' | 'jantar' | 'lanche' | 'sobremesa'
  servings           Int
  nutritionPerServing Json?
  imageUrl           String?
  createdAt          DateTime  @default(now())

  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  favorites   UserFavorite[]

  @@map("recipes")
}

model Ingredient {
  id               String  @id @default(cuid())
  name             String  @unique
  category         String?
  allergenGroup    String? // e.g. "glúten" | "soja" | "amendoim" | "oleaginosas" | "leite" | "ovo"
  unitDefault      String?
  co2Per100g       Float?
  nutritionPer100g Json?

  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String
  optional     Boolean    @default(false)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  order        Int
  instruction  String
  timerSeconds Int?

  @@map("recipe_steps")
}

model UserFavorite {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  savedAt  DateTime @default(now())

  @@unique([userId, recipeId])
  @@map("user_favorites")
}

model NewsArticle {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  kicker          String
  excerpt         String
  content         Json
  tags            String[]
  coverImageUrl   String?
  authorName      String
  authorRole      String?
  authorAvatarUrl String?
  readTimeMin     Int
  isFeatured      Boolean    @default(false)
  status          NewsStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("news_articles")
}
