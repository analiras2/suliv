generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DietPreference {
  vegano
  vegetariano
  flexitariano
}

enum CookingLevel {
  iniciante
  intermediario
  avancado
}

enum CookingFrequency {
  raramente
  algumas_vezes_semana
  quase_todo_dia
}

enum AccountStatus {
  active
  anonymized
}

enum DevicePlatform {
  ios
  android
}

enum AllergenStatus {
  approved
  pending
}

enum RecipeCategory {
  cafe_da_manha
  almoco_jantar
  lanche
  sobremesa
  bebida
  molhos_acompanhamentos
}

enum TimeBucket {
  ate_15
  quinze_30
  trinta_60
  sessenta_mais
}

enum RecipeStatus {
  rascunho
  em_analise
  aprovada
  precisa_de_ajustes
  removida
}

enum AdjustmentReason {
  ingrediente_ambiguo
  passo_confuso
  falta_foto
  foto_baixa_qualidade
  tempo_porcao_incoerente
  conteudo_inadequado
  outro
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  name                  String?
  username              String            @unique
  usernameUpdatedAt     DateTime?         @map("username_updated_at")
  avatarUrl             String?           @map("avatar_url")
  dietPreference        DietPreference?   @map("diet_preference")
  cookingLevel          CookingLevel?     @map("cooking_level")
  cookingFrequency      CookingFrequency? @map("cooking_frequency")
  onboardingCompletedAt DateTime?         @map("onboarding_completed_at")
  termsVersionAccepted  String?           @map("terms_version_accepted")
  termsAcceptedAt       DateTime?         @map("terms_accepted_at")
  status                AccountStatus     @default(active)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  allergies       UserAllergy[]
  deviceTokens    DeviceToken[]
  analyticsEvents AnalyticsEvent[]
  recipes         Recipe[]

  @@map("users")
}

model UserAllergy {
  userId     String   @map("user_id")
  allergenId String   @map("allergen_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergen   Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([userId, allergenId])
  @@map("user_allergies")
}

model Allergen {
  id        String         @id @default(uuid())
  name      String         @unique
  status    AllergenStatus @default(pending)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  userAllergies UserAllergy[]

  @@map("allergens")
}

model DeviceToken {
  id       String         @id @default(uuid())
  userId   String         @map("user_id")
  token    String         @unique
  platform DevicePlatform
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model AnalyticsEvent {
  id         String         @id @default(uuid())
  userId     String?        @map("user_id")
  sessionId  String         @map("session_id")
  platform   DevicePlatform
  appVersion String         @map("app_version")
  eventName  String         @map("event_name")
  properties Json
  occurredAt DateTime       @map("occurred_at")
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, occurredAt])
  @@map("analytics_events")
}

model Category {
  id    String         @id @default(uuid())
  key   RecipeCategory @unique
  label String

  recipes Recipe[]

  @@map("categories")
}

model Recipe {
  id                       String            @id @default(uuid())
  slug                     String            @unique
  authorId                 String?           @map("author_id")
  title                    String
  description              String
  coverImageUrl            String?           @map("cover_image_url")
  categoryId               String            @map("category_id")
  prepTimeMinutes          Int               @map("prep_time_minutes")
  timeBucket               TimeBucket        @map("time_bucket")
  servings                 Int
  difficulty               CookingLevel
  dietPreference           DietPreference    @map("diet_preference")
  status                   RecipeStatus      @default(rascunho)
  currentVersion           Int               @default(1) @map("current_version")
  adjustmentReason         AdjustmentReason? @map("adjustment_reason")
  adjustmentNote           String?           @map("adjustment_note")
  authorMessageToModerator String?           @map("author_message_to_moderator")
  termsVersionAccepted     String?           @map("terms_version_accepted")
  submittedAt              DateTime?         @map("submitted_at")
  approvedAt               DateTime?         @map("approved_at")
  removedAt                DateTime?         @map("removed_at")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")

  user       User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category   Category           @relation(fields: [categoryId], references: [id])
  dailyStats RecipeDailyStats[]

  @@index([status])
  @@index([categoryId, status])
  @@map("recipes")
}

model RecipeDailyStats {
  recipeId        String   @map("recipe_id")
  date            DateTime @db.Date
  opens           Int      @default(0)
  favoritesAdded  Int      @default(0) @map("favorites_added")
  cookCompletions Int      @default(0) @map("cook_completions")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([recipeId, date])
  @@map("recipe_daily_stats")
}
