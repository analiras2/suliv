generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DietPreference {
  vegano
  vegetariano
  flexitariano
}

enum CookingLevel {
  iniciante
  intermediario
  avancado
}

enum CookingFrequency {
  raramente
  algumas_vezes_semana
  quase_todo_dia
}

enum AccountStatus {
  active
  anonymized
}

enum DevicePlatform {
  ios
  android
}

enum AllergenStatus {
  approved
  pending
}

enum RecipeCategory {
  cafe_da_manha
  almoco_jantar
  lanche
  sobremesa
  bebida
  molhos_acompanhamentos
}

enum TimeBucket {
  ate_15
  quinze_30
  trinta_60
  sessenta_mais
}

enum RecipeStatus {
  rascunho
  em_analise
  aprovada
  precisa_de_ajustes
  removida
}

enum AdjustmentReason {
  ingrediente_ambiguo
  passo_confuso
  falta_foto
  foto_baixa_qualidade
  tempo_porcao_incoerente
  conteudo_inadequado
  outro
}

enum IngredientUnit {
  g
  kg
  ml
  l
  unidade
  xicara
  colher_sopa
  colher_cha
  pitada
  a_gosto
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  name                  String?
  username              String            @unique
  usernameUpdatedAt     DateTime?         @map("username_updated_at")
  avatarUrl             String?           @map("avatar_url")
  dietPreference        DietPreference?   @map("diet_preference")
  cookingLevel          CookingLevel?     @map("cooking_level")
  cookingFrequency      CookingFrequency? @map("cooking_frequency")
  onboardingCompletedAt DateTime?         @map("onboarding_completed_at")
  termsVersionAccepted  String?           @map("terms_version_accepted")
  termsAcceptedAt       DateTime?         @map("terms_accepted_at")
  status                AccountStatus     @default(active)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  allergies       UserAllergy[]
  deviceTokens    DeviceToken[]
  analyticsEvents AnalyticsEvent[]
  recipes         Recipe[]

  @@map("users")
}

model UserAllergy {
  userId     String   @map("user_id")
  allergenId String   @map("allergen_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergen   Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([userId, allergenId])
  @@map("user_allergies")
}

model Allergen {
  id        String         @id @default(uuid())
  name      String         @unique
  status    AllergenStatus @default(pending)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  userAllergies UserAllergy[]

  @@map("allergens")
}

model DeviceToken {
  id       String         @id @default(uuid())
  userId   String         @map("user_id")
  token    String         @unique
  platform DevicePlatform
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model AnalyticsEvent {
  id         String         @id @default(uuid())
  userId     String?        @map("user_id")
  sessionId  String         @map("session_id")
  platform   DevicePlatform
  appVersion String         @map("app_version")
  eventName  String         @map("event_name")
  properties Json
  occurredAt DateTime       @map("occurred_at")
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, occurredAt])
  @@map("analytics_events")
}

model Category {
  id    String         @id @default(uuid())
  key   RecipeCategory @unique
  label String

  recipes Recipe[]

  @@map("categories")
}

model Recipe {
  id                       String            @id @default(uuid())
  slug                     String            @unique
  authorId                 String?           @map("author_id")
  title                    String
  description              String
  coverImageUrl            String?           @map("cover_image_url")
  categoryId               String            @map("category_id")
  prepTimeMinutes          Int               @map("prep_time_minutes")
  timeBucket               TimeBucket        @map("time_bucket")
  servings                 Int
  difficulty               CookingLevel
  dietPreference           DietPreference    @map("diet_preference")
  status                   RecipeStatus      @default(rascunho)
  currentVersion           Int               @default(1) @map("current_version")
  adjustmentReason         AdjustmentReason? @map("adjustment_reason")
  adjustmentNote           String?           @map("adjustment_note")
  authorMessageToModerator String?           @map("author_message_to_moderator")
  termsVersionAccepted     String?           @map("terms_version_accepted")
  submittedAt              DateTime?         @map("submitted_at")
  approvedAt               DateTime?         @map("approved_at")
  removedAt                DateTime?         @map("removed_at")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")

  // Kept in sync via DB triggers (not a native Prisma-managed generated
  // column) because it depends on the joined categories.label — see the
  // 20260716190000_add_recipe_search_vector migration and ADR-002.
  searchVector Unsupported("tsvector")? @map("search_vector")

  user        User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category    Category           @relation(fields: [categoryId], references: [id])
  dailyStats  RecipeDailyStats[]
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  versions    RecipeVersion[]

  @@index([status])
  @@index([categoryId, status])
  @@index([searchVector], type: Gin)
  @@map("recipes")
}

model RecipeVersion {
  id            String   @id @default(uuid())
  recipeId      String   @map("recipe_id")
  versionNumber Int      @map("version_number")
  snapshot      Json
  createdAt     DateTime @default(now()) @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, versionNumber])
  @@map("recipe_versions")
}

model RecipeIngredient {
  id                 String         @id @default(uuid())
  recipeId           String         @map("recipe_id")
  name               String
  quantity           Decimal?
  unit               IngredientUnit
  scalesWithServings Boolean        @default(true) @map("scales_with_servings")
  order              Int

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, order])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id              String @id @default(uuid())
  recipeId        String @map("recipe_id")
  order           Int
  description     String
  stepTimeSeconds Int?   @map("step_time_seconds")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, order])
  @@map("recipe_steps")
}

model RecipeDailyStats {
  recipeId        String   @map("recipe_id")
  date            DateTime @db.Date
  opens           Int      @default(0)
  favoritesAdded  Int      @default(0) @map("favorites_added")
  cookCompletions Int      @default(0) @map("cook_completions")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([recipeId, date])
  @@map("recipe_daily_stats")
}

model RecipeAllergen {
  recipeId   String @map("recipe_id")
  allergenId String @map("allergen_id")

  @@id([recipeId, allergenId])
  @@map("recipe_allergens")
}

model EditorialBoost {
  id               String   @id @default(uuid())
  recipeId         String   @map("recipe_id")
  weight           Int
  appliedByAdminId String?  @map("applied_by_admin_id") // not yet a real FK — ADR-003
  startsAt         DateTime @map("starts_at")
  endsAt           DateTime @map("ends_at")

  @@map("editorial_boosts")
}

model SyncOperation {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  idempotencyKey String   @map("idempotency_key")
  actionType     String   @map("action_type")
  appliedAt      DateTime @default(now()) @map("applied_at")

  @@unique([userId, idempotencyKey])
  @@map("sync_operations")
}

enum CommentStatus {
  visible
  hidden
}

model CommentRating {
  id          String        @id @default(uuid())
  recipeId    String        @map("recipe_id")
  userId      String        @map("user_id")
  rating      Int
  commentText String?       @map("comment_text")
  status      CommentStatus @default(visible)
  // Not in the TechSpec's literal Prisma block, but required to implement
  // the §19.5.8 20/day rate limit (a MUST for this task): updatedAt is the
  // only available per-row time signal, and it already doubles as the
  // "avaliar de novo atualiza ... updated_at" field the schema-spec prose
  // (§3.11) references.
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@unique([recipeId, userId])
  @@index([recipeId, status])
  @@map("comments_ratings")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  recipeId  String   @map("recipe_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, recipeId])
  @@map("favorites")
}

enum ReportTargetType {
  recipe
  comment
}

enum ReportReason {
  conteudo_inadequado
  spam
  informacao_incorreta_perigosa
  discurso_odio_assedio
  outro
}

enum ReportStatus {
  pending
  reviewed
}

model Report {
  id                String           @id @default(uuid())
  reporterUserId    String           @map("reporter_user_id")
  targetType        ReportTargetType @map("target_type")
  targetId          String           @map("target_id")
  reason            ReportReason
  freeText          String?          @map("free_text")
  status            ReportStatus     @default(pending)
  reviewedByAdminId String?          @map("reviewed_by_admin_id")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@unique([reporterUserId, targetType, targetId])
  @@map("reports")
}
